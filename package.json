{
  "name": "nuxt-changelog-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "preview": "nuxt preview",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "lint:check": "eslint . --ext .js,.ts,.vue --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "nuxt prepare && nuxi typecheck",
    "precommit": "npm run lint:check && npm run format:check && npm run type-check"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@nuxt/eslint": "1.16.0",
    "cheerio": "^1.1.2",
    "mongodb": "^6.8.0",
    "nodemailer": "^7.0.6",
    "nuxt": "^3.12.0",
    "ofetch": "^1.4.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vite-pwa/nuxt": "^1.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.9",
    "typescript": "^6.0.3"
  }
}
